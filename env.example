# Database
DATABASE_URL="postgresql://username:password@localhost:5432/vocab_quest"

# NextAuth.js (required for Google sign-in)
NEXTAUTH_URL="https://vocabulary-proj.vercel.app"
NEXTAUTH_SECRET="generate-a-long-random-string"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Media Storage (optional - for production)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="vocab-quest-media"

# Analytics (optional)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# Feature Flags (optional)
LAUNCHDARKLY_SDK_KEY=""

# Android APK download URL (optional — default: /downloads/VocabQuest.apk)
NEXT_PUBLIC_APK_URL=""
